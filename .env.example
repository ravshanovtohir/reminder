BOT_TOKEN=123456789:telegram-bot-token
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reminder_bot
TELEGRAM_CHANNEL_ID=@your_channel_username

# Optional
PORT=3000
REMINDER_TIMEZONE=Asia/Samarkand
REMINDER_START_TIME=08:00
REMINDER_INTERVAL_HOURS=1
TELEGRAM_REACTION_EMOJI=❤

# Telegram user IDs allowed to use /test, /schedule and /debug.
# Get your ID by sending /id to the bot.
TELEGRAM_ADMIN_IDS=
